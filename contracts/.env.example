# =============================================================================
# Push Chain Donut testnet (chain 42101)
# =============================================================================
# Copy to `.env`, fill in PRIVATE_KEY, then load + run:
#
#   set -a; source .env; set +a   # -a auto-exports every assignment
#   forge script script/DeployPUSDPlus.v2.s.sol:DeployPUSDPlusV2 \
#     --rpc-url push_testnet --broadcast
#
# Notes:
#   * Use `--rpc-url push_testnet` — it's a foundry.toml alias for the Donut
#     RPC and doesn't depend on the shell env. `--rpc-url $PUSH_RPC` only
#     works AFTER `set -a; source .env; set +a` (or after `export PUSH_RPC=...`).
#   * Add `--verify --verifier blockscout --verifier-url $VERIFIER_URL` to
#     submit verified sources to the Donut Blockscout instance.
# =============================================================================

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------

PUSH_RPC=https://evm.donut.rpc.push.org/
PUSH_CHAIN_ID=42101

# -----------------------------------------------------------------------------
# Signing
# -----------------------------------------------------------------------------

# Deployer key — must hold UPGRADER_ROLE + DEFAULT_ADMIN_ROLE + ADMIN_ROLE on
# PUSDManager when running the v2 upgrade flow. The script does a precheck
# before any tx is sent, so a wrong key surfaces as a clear error rather than
# a mid-flight revert.
PRIVATE_KEY=0x...

# Final admin / DEFAULT_ADMIN holder.
# - V1 scripts: receives admin/upgrader after deploy if different from the
#   deployer; otherwise the deployer keeps both roles.
# - V2 scripts: also DEFAULT_ADMIN on the new PUSDPlusVault + InsuranceFund.
ADMIN_ADDRESS=0xA1c1AF949C5752E9714cFE54f444cE80f078069A

# =============================================================================
# V2 (PUSD+) — additional vars for DeployPUSDPlus.v2.s.sol and DeployFull.s.sol
# =============================================================================

# Existing deployed proxies (used by DeployPUSDPlus.v2.s.sol when upgrading).
# DeployFull.s.sol ignores these — it deploys PUSD/PUSDManager fresh.
# Donut testnet (Deployment 3, 2026-04-22):
PUSD_PROXY=0x488d080e16386379561a47A4955D22001d8A9D89
PUSD_MANAGER_PROXY=0x7A24Eea43a1095e9Dc652AB9Cba156a93Ed5Ed46

# --- v2 PUSD+ contracts deployed on top of v3 (2026-05-04) ---
PUSD_PLUS_VAULT_ADDRESS=0xb55a5B36d82D3B7f18Afe42F390De565080A49a1
INSURANCE_FUND_ADDRESS=0xFF7E741621ad5d39015759E3d606A631Fa319a62

# Push Chain Uniswap V3-compatible AMM (Donut testnet).
# Source: https://push.org/agents/contract-addresses.json (v1.2.0, 2026-04-24)
UNI_V3_NPM=0xf9b3ac66aed14A2C7D9AA7696841aB6B27a6231e
UNI_V3_FACTORY=0x81b8Bca02580C7d6b636051FDb7baAC436bFb454

# Other AMM addresses for reference (not used by the deploy script):
#   SwapRouter   = 0x5D548bB9E305AAe0d6dc6e6fdc3ab419f6aC0037
#   QuoterV2     = 0x83316275f7C2F79BC4E26f089333e88E89093037
#   TickLens     = 0xb64113Fc16055AfE606f25658812EE245Aa41dDC
#   Multicall    = 0xa8c00017955c8654bfFbb6d5179c99f5aB8B7849
#   WPC (wrapped native) = 0xE17DD2E0509f99E9ee9469Cf6634048Ec5a3ADe9

# Operational accounts. For testnet bootstrap these can all be the deployer.
KEEPER_BOT=0xA1c1AF949C5752E9714cFE54f444cE80f078069A
POOL_ADMIN_MULTISIG=0xA1c1AF949C5752E9714cFE54f444cE80f078069A
VAULT_ADMIN_MULTISIG=0xA1c1AF949C5752E9714cFE54f444cE80f078069A
GUARDIAN_MULTISIG=0xA1c1AF949C5752E9714cFE54f444cE80f078069A

# Optional — set to "true" to also upgrade the PUSD ERC-20 implementation.
# PUSD itself isn't modified in v2; default off.
UPGRADE_PUSD=false

# =============================================================================
# Verification (optional — for `forge script ... --verify`)
# =============================================================================

# BlockScout doesn't require an API key. To verify, append:
#   --verify --verifier blockscout --verifier-url $VERIFIER_URL
VERIFIER=blockscout
VERIFIER_URL=https://donut.push.network/api
