{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "yarn build && echo 'pusd.push.org' > ./dist/CNAME && cd dist && git init -b gh-pages && git add -A && git commit -m \"Deploy $(date '+%Y-%m-%d %H:%M')\" && git push --force git@github.com:pushchain/push-chain-pusd-prod-deployment.git gh-pages && cd .. && rm -rf dist/.git"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.1.0",
    "@fontsource/ibm-plex-mono": "^5.1.0",
    "@fontsource/inter": "^5.1.0",
    "@pushchain/ui-kit": "^5.2.8",
    "buffer": "^6.0.3",
    "ethers": "6.16.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2"
  }
}
