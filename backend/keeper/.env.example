RPC_URL=https://evm.donut.rpc.push.org/
CHAIN_ID=42101
PUSD_MANAGER=0x7A24Eea43a1095e9Dc652AB9Cba156a93Ed5Ed46
PUSD_PLUS_VAULT=0xb55a5B36d82D3B7f18Afe42F390De565080A49a1

# Hex private key for the keeper signing wallet (must hold KEEPER_ROLE on the vault).
# In production this is sourced from KMS; for local dev keep it out of git.
KEEPER_PRIVATE_KEY=

# Loop interval. Default 12h; testable at 60s.
LOOP_INTERVAL_MS=43200000

# Page size for rebalanceBatch. 0 = use unbounded rebalance().
REBALANCE_PAGE_SIZE=0

# Skip writes; only read + log.
DRY_RUN=false

LOG_LEVEL=info
